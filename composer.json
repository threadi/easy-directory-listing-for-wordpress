{
    "name": "threadi/easy-directory-listing-for-wordpress",
    "version": "4.1.0",
    "description": "Provides a react-driven directory listing for WordPress plugins and themes.",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
      {
        "name": "Thomas Zwirner",
        "email": "info@thomaszwirner.de"
      }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "post-install-cmd": [
            "\"vendor/bin/phpcs\" --config-set installed_paths vendor/wp-coding-standards/wpcs,vendor/phpcsstandards/phpcsutils,vendor/phpcsstandards/phpcsextra,vendor/sirbrillig/phpcs-variable-analysis,vendor/automattic/vipwpcs"
        ],
        "post-update-cmd": [
            "\"vendor/bin/phpcs\" --config-set installed_paths vendor/wp-coding-standards/wpcs,vendor/phpcsstandards/phpcsutils,vendor/phpcsstandards/phpcsextra,vendor/sirbrillig/phpcs-variable-analysis,vendor/automattic/vipwpcs"
        ]
    },
    "autoload": {
        "psr-4": {
            "easyDirectoryListingForWordPress\\": "lib/"
        }
    },
  "config": {
      "allow-plugins": {
        "dealerdirect/phpcodesniffer-composer-installer": true,
        "phpstan/extension-installer": true,
        "composer/installers": true
      },
      "optimize-autoloader": true,
      "classmap-authoritative": true,
      "apcu-autoloader": true,
      "prepend-autoloader": false,
      "platform-check": false
    },
    "require-dev": {
      "wp-coding-standards/wpcs": "^3.1.0",
      "pronamic/wp-documentor": "^1.3.2",
      "automattic/vipwpcs": "^3.0",
      "phpstan/phpstan": "^2.1",
      "szepeviktor/phpstan-wordpress": "^2.0",
      "phpstan/extension-installer": "^1.4",
      "php-stubs/wp-cli-stubs": "^2.11",
      "phpcompatibility/phpcompatibility-wp": "^2.1",
      "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },
    "require": {
        "php": "^8.0",
        "threadi/crypt-for-wordpress": "^1.2.0"
    }
}
